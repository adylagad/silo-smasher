AIRBYTE_SERVER_URL=http://localhost:8000/api/public/v1
# Optional: set one of these auth strategies.
# AIRBYTE_BEARER_TOKEN=your_token
# AIRBYTE_USERNAME=airbyte
# AIRBYTE_PASSWORD=password

# Optional: set explicitly if you do not want "first workspace" auto-detection.
# AIRBYTE_WORKSPACE_ID=00000000-0000-0000-0000-000000000000

# Required: source definition id for the synthetic source connector.
# AIRBYTE_SOURCE_DEFINITION_ID=00000000-0000-0000-0000-000000000000

# Optional: destination used for connection + sync.
# AIRBYTE_DESTINATION_ID=00000000-0000-0000-0000-000000000000

# Senso configuration (required for --publish-to-senso in build-agent-context).
# SENSO_API_KEY=your_senso_api_key
SENSO_BASE_URL=https://sdk.senso.ai/api/v1
SENSO_POLL_SECONDS=2
SENSO_TIMEOUT_SECONDS=120
