AIRBYTE_SERVER_URL=http://localhost:8000/api/public/v1
# Unique secrets you must provide in your own .env:
# AIRBYTE_BEARER_TOKEN, AIRBYTE_PASSWORD, SENSO_API_KEY,
# NEO4J_PASSWORD, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY,
# OPENAI_API_KEY, GEMINI_API_KEY, FASTINO_API_KEY, YUTORI_API_KEY, NUMERIC_API_KEY, TAVILY_API_KEY

# Optional: set one of these auth strategies.
# AIRBYTE_BEARER_TOKEN=your_token
# AIRBYTE_USERNAME=airbyte
# AIRBYTE_PASSWORD=password

# Optional: set explicitly if you do not want "first workspace" auto-detection.
# AIRBYTE_WORKSPACE_ID=00000000-0000-0000-0000-000000000000

# Required: source definition id for the synthetic source connector.
# AIRBYTE_SOURCE_DEFINITION_ID=00000000-0000-0000-0000-000000000000

# Optional: destination used for connection + sync.
# AIRBYTE_DESTINATION_ID=00000000-0000-0000-0000-000000000000

# Senso configuration (required for --publish-to-senso in build-agent-context).
# SENSO_API_KEY=your_senso_api_key
SENSO_BASE_URL=https://sdk.senso.ai/api/v1
SENSO_POLL_SECONDS=2
SENSO_TIMEOUT_SECONDS=120

# Neo4j AuraDB + AWS Bedrock GraphRAG configuration.
# Example URI format: neo4j+s://<instance-id>.databases.neo4j.io
# NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your_aura_password
NEO4J_DATABASE=neo4j
NEO4J_VECTOR_INDEX=entity_embedding_index

# AWS region must match your Bedrock-enabled region.
# AWS_REGION=us-east-1
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# OpenAI orchestrator configuration.
# OPENAI_API_KEY=your_openai_api_key
ORCHESTRATOR_PRIMARY_PROVIDER=openai
ORCHESTRATOR_ENABLE_GEMINI_FALLBACK=true
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOOL_ROUNDS=8

# Gemini fallback configuration.
# GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Fastino guardrails configuration (PII redaction + action safety checks).
# FASTINO_API_KEY=your_fastino_api_key
FASTINO_BASE_URL=https://api.fastino.ai
FASTINO_GUARDRAILS_ENABLED=true
FASTINO_PII_THRESHOLD=0.35
FASTINO_ACTION_THRESHOLD=0.5
FASTINO_TIMEOUT_SECONDS=10
FASTINO_FAIL_MODE=open

# Yutori web navigation configuration (internal portal fallback data extraction).
# YUTORI_API_KEY=your_yutori_api_key
YUTORI_BASE_URL=https://api.yutori.com
YUTORI_POLL_SECONDS=3
YUTORI_TASK_TIMEOUT_SECONDS=180
YUTORI_HTTP_TIMEOUT_SECONDS=30
YUTORI_MAX_STEPS=75

# Numeric finance variance analysis configuration.
# NUMERIC_API_KEY=your_numeric_api_key
NUMERIC_BASE_URL=https://api.numeric.io
NUMERIC_VARIANCE_PATH=/v1/variance/analysis
NUMERIC_TIMEOUT_SECONDS=20
NUMERIC_MATERIALITY_THRESHOLD_PCT=0.1
NUMERIC_FALLBACK_ENABLED=true

# Tavily external-world search configuration.
# TAVILY_API_KEY=your_tavily_api_key
TAVILY_BASE_URL=https://api.tavily.com
TAVILY_SEARCH_PATH=/search
TAVILY_TIMEOUT_SECONDS=20
TAVILY_TOPIC=news
TAVILY_SEARCH_DEPTH=basic
TAVILY_INCLUDE_ANSWER=basic
TAVILY_FALLBACK_ENABLED=true
